{
  "name": "jaxon-neo-terminal",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern github-pages-dist",
    "test": "npm run build && node --experimental-strip-types --test tests/cancellable-scroll.test.mjs tests/hash-navigation.test.mjs tests/rendered-html.test.mjs tests/scroll-performance-contract.test.mjs",
    "export:github-pages": "npm run build && npm run export:github-pages:from-build",
    "export:github-pages:from-build": "node scripts/export-github-pages.mjs",
    "test:export": "node --test tests/github-pages-export.test.mjs",
    "test:browser": "node --test tests/browser-release-gate.test.mjs",
    "verify": "npm run lint && npm test && npm run export:github-pages:from-build && npm run test:export && npm run test:browser"
  },
  "dependencies": {
    "@fontsource-variable/oxanium": "^5.3.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
